# Copy this file to .env.local and fill in real values.
# Never commit .env.local. See /docs/3_SECURITY_AND_ACCESS.md.

# Sanity (read-only project id and dataset, safe to expose to the client)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=development
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# Sanity write access, server only, never prefix with NEXT_PUBLIC_. Used by
# the migration script and any server route that writes to Sanity.
SANITY_API_WRITE_TOKEN=

# Shared secret the Sanity webhook must send to trigger ISR revalidation
SANITY_REVALIDATE_SECRET=

# Maps: use whichever provider is chosen, restrict the key by HTTP referrer
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number the site links to, digits only, country code first, no plus sign
NEXT_PUBLIC_WHATSAPP_NUMBER=
